generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id String @id @default(uuid())

  nome               String
  nomeSocial         String?  @map("nome_social")
  dataNasc           DateTime @map("data_nasc")
  naturalidade       String
  emailInstitucional String   @unique @map("email_institucional")
  emailSecundario    String   @map("email_secundario")
  senha              String

  nomeMae String @map("nome_mae")
  nomePai String @map("nome_pai")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  sexo      Sexo
  raca      Raca
  alunos    Aluno?
  professor Professor?
  cargos    Cargo[]

  tituloEleitor TituloEleitor?

  fkIdentidade String @unique @map("fk_identidade")
  fkEndereco   Int    @map("fk_endereco")

  endereco   Endereco   @relation(fields: [fkEndereco], references: [id])
  identidade Identidade @relation(fields: [fkIdentidade], references: [id])
  historico  Historico[]

  @@map("usuario")
}

model Aluno {
  id String @id @default(uuid())

  matricula String @unique

  inscricaos Inscricao[]
  historico  Historico[]

  fkUsuario String  @unique @map("fk_usuario")
  usuario   Usuario @relation(fields: [fkUsuario], references: [id])

  @@map("aluno")
}

model Professor {
 id String @id @default(uuid())

  siape                   String   @unique
  emailSiape              String?  @unique @map("email_siape")
  
  telefonesInstitucionais String[]  @default([]) @map("telefones_institucionais")
  telefonesPessoais       String[]  @default([]) @map("telefones_pessoais")
  emPGD                   Boolean?
  emailNotificacoes       String?   @map("email_notificacoes") // Campo Novo
  emailClassroom          String?   @map("email_classroom")    // Campo Novo

  titulacao               String?
  escolaridade            String?
  grupoSanguineo          String?  @map("grupo_sanguineo")

  setorSuap               String?  @map("setor_suap")
  lotacaoSiape            String?  @map("lotacao_siape")
  exercicioSiape          String?  @map("execicio_siape")
  situacao                String?
  regimeTrabalho          String?  @map("regime_trabalho")
  jornadaTrabalho         String?  @map("jornada_trabalho")
  operadorRaioX           Boolean? @map("operador_raiox")

  inicioServicoPublico    DateTime? @map("inicio_servico_publico") @db.Date
  dataDePosseInstituicao  DateTime? @map("data_posse_instituicao") @db.Date
  inicioServicoInstituicao DateTime? @map("inicio_servico_instituicao") @db.Date
  tempoServicoInstituicaao String?   @map("tempo_servico_instituicao")
  dataPosseCargo          DateTime? @map("data_posse_cargo") @db.Date
  inicioExercicioCargo    DateTime? @map("inicio_exercicio_cargo") @db.Date
  tempoServicoCargo       DateTime? @map("tempo_servico_cargo") @db.Date
  cargoInstitucional      String?   @map("cargo_institucional")
  classeCargo             String?   @map("classe_cargo")
  padrao                  String?
  grupoCargo              String?   @map("grupo_cargo")
  codigoVaga              Int?      @map("codigo_vaga")
  NCE                     String?

  qtdDependentes Int?    @map("qtd_dependentes")
  pisPasep       String? @map("pis_pasep")

  alocacoes AlocacaoProfessor[]

  fkUsuario String  @unique @map("fk_usuario")
  usuario   Usuario @relation(fields: [fkUsuario], references: [id])

  @@map("professor")
}

model Endereco {
  id Int @id @default(autoincrement())

  rua    String
  bairro String
  numero Int
  cep    Int

  usuario Usuario[]

  @@map("endereco")
}

model DadosBancarios {
  id String @id @default(uuid())

  banco   String
  agencia Int
  cc      Int

  @@map("dados_bancarios")
}

model Curso {
  id String @id @default(uuid())

  nome          String
  carga_horaria Int
  vagas         Int
  status        StatusCurso @default(ANALISE)
  dataInicio    DateTime    @map("data_inicio") @db.Date
  dataFim       DateTime    @map("data_fim") @db.Date
  horarioInicio DateTime    @map("horario_inicio") @db.Time()
  horarioFim    DateTime    @map("horario_fim") @db.Time()

  professores AlocacaoProfessor[]
  diasSemana  DiasSemana[]        @map("dias_semana")
  inscricao   Inscricao[]

  fkInstituicao String      @map("fk_instituicao")
  Instituicao   Instituicao @relation(fields: [fkInstituicao], references: [id])

  @@map("curso")
}

model AlocacaoProfessor {
  id String @id @default(uuid())

  fkProfessor String @map("fk_professor")
  fkCurso     String @map("fk_curso")

  professor Professor @relation(fields: [fkProfessor], references: [id])
  curso     Curso     @relation(fields: [fkCurso], references: [id])

  cargaHoraria Int      @map("carga_horaria")
  dataAlocacao DateTime @default(now()) @map("data_alocacao")

  @@unique([fkProfessor, fkCurso])
  @@map("alocacao_professor ")
}

model Instituicao {
  id String @id @default(uuid())

  nome   String
  cidade String
  campus String
  cnpj   String @unique

  cursos Curso[]

  @@map("instituicao")
}

model Inscricao {
  id String @id @default(uuid())

  data DateTime @default(now())

  status        StatusInscricao @default(PENDENTE) @map("curso_status")
  rendaFamiliar RendaFamiliar?
  historico     Historico[]
  documentos    Documento[]

  fkAluno String @map("fk_aluno")
  aluno   Aluno  @relation(fields: [fkAluno], references: [id])

  fkCurso String @map("fk_curso")
  curso   Curso  @relation(fields: [fkCurso], references: [id])

  @@map("inscricao")
}

model Identidade {
  id String @id @default(uuid())

  rg            String   @unique
  cpf           String   @unique
  orgaoEmissor  String   @map("orgao_emissor")
  estado        String
  dataExpedicao DateTime @map("data_expedicao") @db.Date

  usuario Usuario?

  @@map("identidade")
}

model TituloEleitor {
  id String @id @default(uuid())

  numero         String
  zonaEleitoral  String @map("zona_eleitoral")
  secaoEleitoral String @map("secao_eleitoral")
  UF             String

  fkUsuario String @unique @map("fk_usuario")
  usuario   Usuario @relation(fields: [fkUsuario], references: [id])

  @@map("titulo_eleitor")
}

model RendaFamiliar {
  id String @id @default(uuid())

  rendaFamiliar Float @map("renda_familiar")
  numeroPessoas Int   @map("numero_pessoas")

  fkInscricao String    @unique @map("fk_inscricao")
  inscricao   Inscricao @relation(fields: [fkInscricao], references: [id])

  @@map("renda_familiar")
}

model Auditoria {
  id String @id @default(uuid())

  tabelaModificada String @map("tabela_modificada")
  acaoRealizada    Acao   @map("acao_realizada")
  idModificado     Int    @map("id_modificado")

  dadosAntigos   Json? @map("dados_antigos")
  dadosInseridos Json? @map("dados_inseridos")

  fkUsuario String? @map("fk_usuario")

  dataModificacao DateTime @default(now()) @map("data_modificacao")

  @@index([tabelaModificada, idModificado])
  @@map("auditoria")
}

model Cargo {
  id    Int     @id
  cargo Cargos
  desc  String?

  usuario    Usuario[]
  permissoes Permissoes[]

  @@map("cargo")
}

model Permissoes {
  id        Int     @id @default(autoincrement())
  permissao String
  desc      String?

  cargo Cargo[]

  @@map("permissoes")
}

model Historico {
  id Int @id @default(autoincrement())

  alteracao       String
  descricao       String
  statusAnterior  StatusInscricao @map("status_anterior")
  statusAtual     StatusInscricao @map("status_atual")
  dataModificacao DateTime        @default(now()) @map("data_modificacao")

  fkAluno              String @map("fk_aluno")
  fkInscricao          String @map("fk_inscricao")
  fkUsuarioResponsavel String @map("fk_usuario_responsavel")

  aluno     Aluno     @relation(fields: [fkAluno], references: [id])
  inscricao Inscricao @relation(fields: [fkInscricao], references: [id])
  usuario   Usuario   @relation(fields: [fkUsuarioResponsavel], references: [id])

  @@map("historico")
}

enum StatusCurso {
  ANDAMENTO
  ANALISE
  CONCLUIDO
  FECHADO
}

enum StatusInscricao {
  PENDENTE
  DEFERIDO
  INDEFERIDO
  CANCELADO
}

enum DiasSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

enum Sexo {
  MASCULINO
  FEMININO
}

enum Raca {
  AMARELA
  BRANCA
  PARDA
  PRETA
  INDIGENA
  NAO_DECLARADO
}

enum Acao {
  CREATE
  UPDATE
  DELETE
}

enum Cargos {
  ALUNO
  PROFESSOR
  ADMIN
  DEPPI
}

model Documento {
  id String @id @default(uuid())

  nomeOriginal String  @map("nome_original")
  nomeArquivo  String  @map("nome_arquivo") // nome único salvo em disco
  caminho      String  // caminho relativo de armazenamento
  tipoMime     String  @map("tipo_mime")
  tamanho      Int     // bytes
  categoria    CategoriaDocumento? @default(OUTRO)

  criadoEm DateTime @default(now()) @map("criado_em")

  fkInscricao String    @map("fk_inscricao")
  inscricao   Inscricao @relation(fields: [fkInscricao], references: [id])

  @@map("documento")
}

enum CategoriaDocumento {
  RG
  CPF
  COMPROVANTE_RESIDENCIA
  COMPROVANTE_RENDA
  HISTORICO_ESCOLAR
  OUTRO
}