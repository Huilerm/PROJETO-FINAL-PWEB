// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id Int @id @default(autoincrement())

  nome         String
  nome_social  String?
  data_nasc    DateTime
  naturalidade String
  email        String   @unique
  senha        String

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  sexo      Sexo
  raca      Raca
  cargos    Cargos[]   @default([ALUNO])
  alunos    Aluno?
  professor Professor?

  fk_identidade Int        @unique
  identidade    Identidade @relation(fields: [fk_identidade], references: [id])
}

model Aluno {
  id Int @id @default(autoincrement())

  matricula String

  inscricaos Inscricao[]

  fk_usuario Int     @unique
  usuario    Usuario @relation(fields: [fk_usuario], references: [id])
}

model Professor {
  id Int @id @default(autoincrement())

  siap String

  alocacoes AlocacaoProfessor[]

  fk_usuario Int     @unique
  usuario    Usuario @relation(fields: [fk_usuario], references: [id])
}

model Curso {
  id Int @id @default(autoincrement())

  nome           String
  carga_horaria  Int
  vagas          Int
  status         StatusCurso @default(ANALISE)
  data_inicio    DateTime    @db.Date
  data_fim       DateTime    @db.Date
  horario_inicio DateTime    @db.Time()
  horario_fim    DateTime    @db.Time()

  professores AlocacaoProfessor[]
  dias_semana DiasSemana[]
  inscricao   Inscricao[]

  fk_instituicao Int
  Instituicao    Instituicao @relation(fields: [fk_instituicao], references: [id])
}

model AlocacaoProfessor {
  id Int @id @default(autoincrement())

  fk_professor Int
  fk_curso     Int

  professor Professor @relation(fields: [fk_professor], references: [id])
  curso     Curso     @relation(fields: [fk_curso], references: [id])

  carga_horaria Int
  dataAlocacao  DateTime @default(now())

  @@unique([fk_professor, fk_curso])
}

model Instituicao {
  id Int @id @default(autoincrement())

  nome   String
  cidade String
  campus String
  cnpj   String

  cursos Curso[]
}

model Inscricao {
  id Int @id @default(autoincrement())

  data DateTime @default(now())

  curso_status   StatusInscricao @default(PENDENTE)
  renda_familiar RendaFamiliar?

  fk_aluno Int
  aluno    Aluno @relation(fields: [fk_aluno], references: [id])

  fk_curso Int
  curso    Curso @relation(fields: [fk_curso], references: [id])
}

model Identidade {
  id Int @id @default(autoincrement())

  rg            String   @unique
  cpf           String   @unique
  orgao_emissor String
  estado        String
  data_emissao  DateTime @db.Date

  usuario Usuario?
}

model RendaFamiliar {
  id Int @id @default(autoincrement())

  renda_familiar Float
  numero_pessoas Int

  fk_inscricao Int       @unique
  inscricao    Inscricao @relation(fields: [fk_inscricao], references: [id])
}

model Auditoria {
  id Int @id @default(autoincrement())

  tabela_modificada String
  acao_realizada    Acao
  id_modificado Int

  dados_antigos Json?
  dados_inseridos Json?

  fk_usuario Int?

  data_modificacao DateTime @default(now())

  @@index([tabela_modificada, id_modificado])
}

enum StatusCurso {
  ANDAMENTO
  ANALISE
  CONCLUIDO
  FECHADO
}

enum StatusInscricao {
  PENDENTE
  DEFERIDO
  INDEFERIDO
}

enum Cargos {
  ALUNO
  PROFESSOR
  DEPPI
  ADMIN
}

enum DiasSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

enum Sexo {
  MASCULINO
  FEMININO
}

enum Raca {
  AMARELA
  BRANCA
  PARDA
  PRETA
  INDIGENA
  NAO_DECLARADO
}

enum Acao {
  CREATE
  UPDATE
  DELETE
}
